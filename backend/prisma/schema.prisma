generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("HOST") // HOST | WORKER | OWNER | CLIENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host    Host?
  worker  Worker?
  owner   Owner?
  client  Client?
  partner Partner?
}

model Host {
  id             String        @id @default(cuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  pushToken         String?
  autoDispatch      Boolean       @default(true)
  notificationPrefs String        @default("{\"guestMessages\":true,\"workerMessages\":true,\"aiConversationAlerts\":true,\"aiIssueAlerts\":\"all\"}")
  properties     Property[]
  tradeRoles     TradeRole[]
  ownersCreated  Owner[]
  tradesmen      Tradesman[]
  workers        Worker[]
  conversations  Conversation[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Property {
  id          String   @id @default(cuid())
  hostId      String
  host        Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name        String
  address     String
  city        String
  country     String
  description String?
  type        String   @default("VILLA")
  bedrooms    Int      @default(1)
  bathrooms   Int      @default(1)
  maxGuests   Int      @default(2)
  amenities   String   @default("[]")
  images      String   @default("[]")
  isActive            Boolean  @default(true)
  airbnbUrl           String?
  caretakerType       String   @default("PART_TIME") // FULL_TIME | PART_TIME
  // Guest experience
  wifiName            String?
  wifiPassword        String?
  mapUrl              String?
  checkInInstructions String?
  houseRules          String?  // JSON array of rule strings
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  bookings            Booking[]
  jobs                Job[]
  inventoryItems      InventoryItem[]
  supplyCabinets      SupplyCabinet[]
  staffAssignments    PropertyStaff[]
  maintenanceSettings PropertyMaintenanceSettings?
  maintenanceRequests MaintenanceRequest[]
  issues              Issue[]
  ownerships          PropertyOwnership[]
  revenueReports      RevenueReport[]
  areas               PropertyArea[]
  docs                PropertyDoc[]
  contacts            PropertyContact[]
  tradesmen           TradesmanProperty[]
  conversations       Conversation[]
}

model Booking {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestName   String
  guestEmail  String?
  guestPhone  String?
  checkIn     DateTime
  checkOut    DateTime
  guestCount  Int      @default(1)
  totalAmount Float
  currency    String   @default("USD")
  status      String   @default("CONFIRMED")
  source      String   @default("DIRECT")
  externalId  String?
  notes       String?
  guestCode   String?  @unique  // short URL token for guest app
  lockCode    String?           // door lock code
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs            Job[]
  serviceRequests GuestServiceRequest[]
  guestIds        GuestID[]
  visitors        GuestVisitor[]
  conversation    Conversation?
}

model GuestID {
  id           String   @id @default(cuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guestName    String
  documentType String   @default("PASSPORT") // PASSPORT | NATIONAL_ID | DRIVERS_LICENSE | OTHER
  documentUrl  String
  createdAt    DateTime @default(now())
}

model GuestVisitor {
  id           String   @id @default(cuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  visitorName  String
  purpose      String?
  expectedDate String?  // "YYYY-MM-DD"
  expectedTime String?  // "HH:MM"
  idUrl        String?
  notes        String?
  createdAt    DateTime @default(now())
}

model GuestServiceRequest {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  propertyId    String
  type          String   // HOUSEKEEPING | COOK | DRIVER | CAR_RENTAL | ARRIVAL_TIME | DEPARTURE_TIME | OTHER
  requestedDate String?  // "YYYY-MM-DD"
  requestedTime String?  // "HH:MM" (housekeeping slot)
  notes         String?
  status        String   @default("PENDING") // PENDING | CONFIRMED | DECLINED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Worker {
  id              String     @id @default(cuid())
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          String     @default("[]")
  isAvailable     Boolean    @default(true)
  location        String?
  city            String?    // for shift marketplace city-based matching
  latitude        Float?
  longitude       Float?
  rating          Float?
  jobsCompleted   Int        @default(0)
  shiftsCompleted Int        @default(0)
  bio             String?
  pushToken       String?
  tradeRoleId     String?
  tradeRole       TradeRole? @relation(fields: [tradeRoleId], references: [id], onDelete: SetNull)
  hostId          String?
  host            Host?      @relation(fields: [hostId], references: [id], onDelete: SetNull)
  isGigWorker     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  jobs                     Job[]
  propertyStaff            PropertyStaff[]
  reportedMaintenanceReqs  MaintenanceRequest[] @relation("ReportedBy")
  assignedMaintenanceReqs  MaintenanceRequest[] @relation("AssignedTo")
  audits                   JobAudit[]
  reportedIssues           Issue[]              @relation("ReportedIssues")
  shiftApplications        ShiftApplication[]
  conversations            Conversation[]
}

model Job {
  id                   String             @id @default(cuid())
  propertyId           String
  property             Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookingId            String?
  booking              Booking?           @relation(fields: [bookingId], references: [id])
  workerId             String?
  worker               Worker?            @relation(fields: [workerId], references: [id])
  type                 String
  status               String             @default("PENDING")
  scheduledAt          DateTime
  completedAt          DateTime?
  completionPhotoUrl   String?
  completionVideoUrl   String?
  notes                String?
  checklist            String?
  archivedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  issues             Issue[]
  maintenanceRequest MaintenanceRequest?
  audit              JobAudit?
}

model Issue {
  id           String    @id @default(cuid())
  jobId        String?   // optional — supervisors can report without a job
  job          Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  propertyId   String?   // set on all new issues; nullable for backwards compat
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reportedById String?   // worker who filed it; nullable for backwards compat
  reportedBy   Worker?   @relation("ReportedIssues", fields: [reportedById], references: [id])
  description  String
  photoUrl     String?
  videoUrl     String?
  severity     String    @default("LOW")
  status       String    @default("OPEN")
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  aiSuggestions AiSuggestion[]
}

model InventoryItem {
  id            String    @id @default(cuid())
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name          String
  category      String    @default("OTHER")
  currentStock  Float     @default(0)
  minStock      Float     @default(1)
  unit          String    @default("units")
  location      String?
  photos        String    @default("[]")  // JSON array of photo URLs
  lastRestocked DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SupplyCabinet {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name        String
  location    String
  photoUrl    String?
  qrCode      String   @unique @default(cuid())
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Maintenance trade roles (host-defined) ──────────────────────────────────

model TradeRole {
  id          String   @id @default(cuid())
  hostId      String
  host        Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name        String   // e.g. "Plumber", "Carpenter", "Electrician"
  description String?
  color       String   @default("#6366f1") // display color
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workers             Worker[]
  maintenanceRequests MaintenanceRequest[]
}

// ── Property staff assignments ───────────────────────────────────────────────

model PropertyStaff {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workerId   String
  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  role       String   @default("CLEANER") // CARETAKER, CLEANER, SUPERVISOR
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([propertyId, workerId])
}

// ── Per-property maintenance approval settings ───────────────────────────────

model PropertyMaintenanceSettings {
  id                   String   @id @default(cuid())
  propertyId           String   @unique
  property             Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requireApproval      Boolean  @default(true)
  autoAssignTradeRoles String   @default("[]") // JSON array of tradeRoleIds
  allowCaretakerAssign Boolean  @default(false) // caretaker can pick the tradesperson
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── Maintenance requests (raised by caretakers / cleaners) ───────────────────

model MaintenanceRequest {
  id               String     @id @default(cuid())
  propertyId       String
  property         Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reportedById     String
  reportedBy       Worker     @relation("ReportedBy", fields: [reportedById], references: [id])
  tradeRoleId      String?
  tradeRole        TradeRole? @relation(fields: [tradeRoleId], references: [id], onDelete: SetNull)
  title            String
  description      String
  photoUrl         String?
  videoUrl         String?
  priority         String     @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status           String     @default("PENDING") // PENDING, APPROVED, REJECTED, AUTO_ASSIGNED, ASSIGNED, IN_PROGRESS, COMPLETED
  assignedWorkerId String?
  assignedWorker   Worker?    @relation("AssignedTo", fields: [assignedWorkerId], references: [id])
  jobId            String?    @unique
  job              Job?       @relation(fields: [jobId], references: [id])
  hostNotes        String?
  scheduledAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

// ── Owner model ──────────────────────────────────────────────────────────────

model Owner {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByHostId  String?
  createdByHost    Host?              @relation(fields: [createdByHostId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  properties PropertyOwnership[]
}

model PropertyOwnership {
  id               String   @id @default(cuid())
  ownerId          String
  owner            Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  propertyId       String
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  involvementLevel String   @default("REPORTS_ONLY") // NONE, REPORTS_ONLY, FINANCIAL, FULL
  ownershipPercent Float?
  commissionPct    Float?   // Management commission % taken from gross revenue
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([ownerId, propertyId])
}

// ── Revenue reports ───────────────────────────────────────────────────────────

model RevenueReport {
  id                String    @id @default(cuid())
  propertyId        String
  property          Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  hostId            String
  month             Int       // 1-12
  year              Int
  grossRevenue      Float     // Airbnb gross earnings (before Airbnb service fee)
  airbnbServiceFees Float     @default(0) // Airbnb's own service fees deducted
  netRevenue        Float     // grossRevenue - airbnbServiceFees (credited to host account)
  commissionPct     Float     @default(20) // Management commission %
  commissionAmount  Float     // Calculated commission amount
  airbnbReportUrl   String?   // Uploaded Airbnb report file URL
  status            String    @default("DRAFT") // DRAFT, PUBLISHED
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  expenses          Expense[]

  @@unique([propertyId, month, year])
}

model Expense {
  id               String        @id @default(cuid())
  reportId         String
  report           RevenueReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  propertyId       String
  category         String        // HOUSEKEEPING, CONSUMABLES, REPAIRS, UTILITIES, MISCELLANEOUS
  description      String
  amount           Float
  expenseType      String        @default("SHARED") // SHARED, OWNER_ONLY
  receiptUrl       String?
  requiresApproval Boolean       @default(false)
  approvalStatus   String        @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedByUserId String?
  approvedAt       DateTime?
  approverNotes    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

// ── Property Operations Guide ─────────────────────────────────────────────────

model PropertyArea {
  id          String        @id @default(cuid())
  propertyId  String
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name        String        // e.g. "1st Floor Laundry Room", "Ground Floor Kitchen"
  floor       String?       // e.g. "Ground Floor", "1st Floor", "Outdoor"
  description String?
  order       Int           @default(0)
  docs        PropertyDoc[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PropertyDoc {
  id          String        @id @default(cuid())
  propertyId  String
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  areaId      String?
  area        PropertyArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)
  title       String        // e.g. "Cleaning Equipment Cabinet"
  description String        // Detailed notes / instructions
  category    String        @default("OTHER") // STORAGE, APPLIANCE, ELECTRICAL, UTILITY, ACCESS, SAFETY, PROCEDURE, OTHER
  photos      String        @default("[]")   // JSON array of photo URLs
  tags        String        @default("[]")   // JSON array of searchable tags
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PropertyContact {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agency     String   // e.g. "Electrician", "Plumber", "HVAC"
  name       String?  // Contact person name
  phones     String   @default("[]") // JSON array of phone number strings
  company    String?
  notes      String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Tradesmen database ────────────────────────────────────────────────────────

model Tradesman {
  id        String   @id @default(cuid())
  hostId    String
  host      Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name      String
  trade     String   // e.g. "Electrician", "Plumber"
  phones    String   @default("[]") // JSON array
  company   String?
  notes     String?
  area      String?  // location/area e.g. "Calangute, Goa"
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties TradesmanProperty[]
}

model TradesmanProperty {
  id          String    @id @default(cuid())
  tradesmanId String
  tradesman   Tradesman @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tradesmanId, propertyId])
}

// ── Supervisor job audits ─────────────────────────────────────────────────────

model JobAudit {
  id           String   @id @default(cuid())
  jobId        String   @unique
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  supervisorId String
  supervisor   Worker   @relation(fields: [supervisorId], references: [id])
  rating       Int      // 1–5
  notes        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── B2B Shift Marketplace ─────────────────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  businessType String   @default("RESTAURANT") // RESTAURANT | HOTEL | VILLA | RETAIL | EVENT | OTHER
  gstNumber    String?
  city         String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  venues Venue[]
  shifts Shift[]
}

model Venue {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  address   String
  city      String
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts Shift[]
}

model Shift {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  venueId       String
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  role          String   // WAITER | BARTENDER | COOK | HOUSEKEEPER | SECURITY | DRIVER | CLEANER | OTHER
  date          String   // "YYYY-MM-DD"
  startTime     String   // "HH:MM"
  endTime       String   // "HH:MM"
  hourlyRate    Float
  currency      String   @default("INR")
  workersNeeded Int      @default(1)
  status        String   @default("OPEN") // OPEN | PARTIALLY_FILLED | FILLED | IN_PROGRESS | COMPLETED | CANCELLED
  notes         String?
  requirements  String   @default("[]") // JSON array of requirement strings
  urgency       String   @default("SCHEDULED") // ASAP | SCHEDULED
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  applications ShiftApplication[]
}

model ShiftApplication {
  id           String    @id @default(cuid())
  shiftId      String
  shift        Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  workerId     String
  worker       Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status       String    @default("PENDING") // PENDING | CONFIRMED | WITHDRAWN | NO_SHOW | COMPLETED
  confirmedAt  DateTime?
  clientRating Int?      // 1-5, submitted post-shift by client
  clientNote   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  checkIn ShiftCheckIn?

  @@unique([shiftId, workerId])
}

model ShiftCheckIn {
  id            String           @id @default(cuid())
  applicationId String           @unique
  application   ShiftApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  checkInAt     DateTime?
  checkOutAt    DateTime?
  hoursWorked   Float?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// Billing, Subscriptions & Partner Program
// ═══════════════════════════════════════════════════════════════════════════════

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
}

enum PartnerTier {
  referral
  channel
  strategic
}

enum PartnerStatus {
  active
  suspended
  pending
  flagged
}

enum CommissionType {
  direct
  override
}

enum CommissionStatus {
  pending
  approved
  paid
  voided
  clawback
}

enum PayoutMethod {
  bank_transfer
  paypal_payout
  stripe_connect
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

// ── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id                  String        @id @default(cuid())
  name                String
  referredByPartnerId String?
  referredByPartner   Partner?      @relation("ReferredOrganizations", fields: [referredByPartnerId], references: [id], onDelete: SetNull)
  signupIp            String?
  signupFingerprint   String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  host         Host?
  subscription Subscription?
}

// ── Plan ─────────────────────────────────────────────────────────────────────

model Plan {
  id               String   @id @default(cuid())
  name             String   // community | pro | agency
  pricePerProperty Float?   // e.g. $10 for Pro
  flatPrice        Float?   // e.g. $100 for Agency
  maxProperties    Int?     // null = unlimited
  features         Json
  createdAt        DateTime @default(now())

  subscriptions Subscription[]
}

// ── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  status             SubscriptionStatus
  paypalSubId        String?
  stripeSubId        String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  propertyCount      Int                @default(0)
  monthlyAmount      Float
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  commissions Commission[]
}

// ── Partner ──────────────────────────────────────────────────────────────────

model Partner {
  id              String        @id @default(cuid())
  userId          String?       @unique
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Public registration fields (no User account required)
  fullName        String?
  email           String?       @unique
  paypalEmail     String?
  country         String?
  promotionMethod String?       // social_media, blog_content, direct_outreach, property_management, real_estate, other
  tier            PartnerTier
  referralCode    String        @unique
  commissionRate  Float
  overrideRate    Float?
  referredById    String?
  referredBy      Partner?      @relation("PartnerReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals       Partner[]     @relation("PartnerReferrals")
  totalEarned     Float         @default(0)
  pendingPayout   Float         @default(0)
  bankDetails     Json?
  status          PartnerStatus
  // Anti-gaming fields
  dailyReferralCount Int        @default(0)
  dailyReferralDate  String?    // "YYYY-MM-DD" for tracking daily cap
  monthlyPayout      Float      @default(0)
  monthlyPayoutMonth String?    // "YYYY-MM" for tracking monthly cap
  suspendReason      String?
  createdAt          DateTime   @default(now())

  commissions            Commission[]
  payouts                Payout[]
  referredOrganizations  Organization[] @relation("ReferredOrganizations")
  flags                  PartnerFlag[]
  referralClicks         ReferralClick[]
}

// ── Commission ───────────────────────────────────────────────────────────────

model Commission {
  id             String           @id @default(cuid())
  partnerId      String
  partner        Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  type           CommissionType
  amount         Float
  currency       String           @default("USD")
  period         String           // e.g. "2026-04"
  status         CommissionStatus
  holdUntil      DateTime?        // 30-day hold before approval
  clawbackUntil  DateTime?        // 60-day clawback window
  paidAt         DateTime?
  payoutId       String?
  payout         Payout?          @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
}

// ── Payout ───────────────────────────────────────────────────────────────────

model Payout {
  id          String       @id @default(cuid())
  partnerId   String
  partner     Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String       @default("USD")
  method      PayoutMethod
  reference   String?
  status      PayoutStatus
  commissions Commission[]
  processedAt DateTime?
  createdAt   DateTime     @default(now())
}

// ── Partner Flags (anti-gaming) ──────────────────────────────────────────────

model PartnerFlag {
  id         String   @id @default(cuid())
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  reason     String   // self_referral, same_ip, domain_match, high_churn, velocity_limit, manual
  details    String?  // JSON details about the flag
  status     String   @default("pending") // pending, approved, rejected, dismissed
  reviewedAt DateTime?
  reviewedBy String?  // admin email
  createdAt  DateTime @default(now())

  @@index([partnerId])
}

// ── Referral Click Tracking ─────────────────────────────────────────────────

model ReferralClick {
  id         String   @id @default(cuid())
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([partnerId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Messaging (Guest↔Host + Internal: Host↔Worker, Supervisor↔Worker)
// ═══════════════════════════════════════════════════════════════════════════════

model Conversation {
  id                 String    @id @default(cuid())
  channelType        String    @default("GUEST_HOST") // GUEST_HOST | HOST_WORKER | SUPERVISOR_WORKER
  bookingId          String?   @unique
  booking            Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostId             String
  host               Host      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  workerId           String?
  worker             Worker?   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  propertyId         String?
  property           Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  guestName          String?
  guestCode          String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadByHost       Int       @default(0)
  unreadByGuest      Int       @default(0)
  unreadByWorker     Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  messages           Message[]
  aiSuggestions      AiSuggestion[]

  @@index([hostId, channelType])
  @@index([workerId, channelType])
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType      String        // "HOST" | "GUEST" | "SYSTEM" | "WORKER" | "SUPERVISOR" | "AI"
  senderName      String
  content         String
  imageUrl         String?
  voiceUrl         String?
  voiceDuration    Int?
  voiceTranscript  String?
  voiceTranslation String?
  voiceLanguage    String?
  visibility      String        @default("ALL")    // "ALL" | "TEAM_ONLY"
  isSystemMessage  Boolean       @default(false)
  readByHost      Boolean       @default(false)
  readByGuest     Boolean       @default(false)
  readByWorker    Boolean       @default(false)
  createdAt       DateTime      @default(now())
  aiSuggestion    AiSuggestion?

  @@index([conversationId, createdAt])
}

model AiSuggestion {
  id              String        @id @default(cuid())
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId       String?       @unique
  message         Message?      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  issueId         String?
  issue           Issue?        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  category        String        // MAINTENANCE, CLEANING, SAFETY, APPLIANCE, PEST, etc.
  urgency         String        // LOW, MEDIUM, HIGH, CRITICAL
  sentiment       String        // POSITIVE, NEUTRAL, NEGATIVE, DISTRESSED
  summary         String
  suggestedAction String        // CREATE_ISSUE, CREATE_JOB, DISPATCH_WORKER, AUTO_REPLY, NOTIFY_ONLY
  suggestedReply  String?
  actionPayload   Json?
  status          String        @default("PENDING") // PENDING, APPROVED, DISMISSED
  createdIssueId  String?
  createdJobId    String?
  createdAt       DateTime      @default(now())

  @@index([conversationId, status])
  @@index([issueId])
}
