generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("HOST")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host   Host?
  worker Worker?
  owner  Owner?
}

model Host {
  id         String      @id @default(cuid())
  userId     String      @unique
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  properties Property[]
  tradeRoles TradeRole[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Property {
  id          String   @id @default(cuid())
  hostId      String
  host        Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name        String
  address     String
  city        String
  country     String
  description String?
  type        String   @default("VILLA")
  bedrooms    Int      @default(1)
  bathrooms   Int      @default(1)
  maxGuests   Int      @default(2)
  amenities   String   @default("[]")
  images      String   @default("[]")
  isActive    Boolean  @default(true)
  airbnbUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings            Booking[]
  jobs                Job[]
  inventoryItems      InventoryItem[]
  supplyCabinets      SupplyCabinet[]
  staffAssignments    PropertyStaff[]
  maintenanceSettings PropertyMaintenanceSettings?
  maintenanceRequests MaintenanceRequest[]
  ownerships          PropertyOwnership[]
  revenueReports      RevenueReport[]
}

model Booking {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestName   String
  guestEmail  String
  guestPhone  String?
  checkIn     DateTime
  checkOut    DateTime
  guestCount  Int      @default(1)
  totalAmount Float
  currency    String   @default("USD")
  status      String   @default("CONFIRMED")
  source      String   @default("DIRECT")
  externalId  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs Job[]
}

model Worker {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills        String     @default("[]")
  isAvailable   Boolean    @default(true)
  location      String?
  rating        Float?
  jobsCompleted Int        @default(0)
  bio           String?
  pushToken     String?
  tradeRoleId   String?
  tradeRole     TradeRole? @relation(fields: [tradeRoleId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  jobs                     Job[]
  propertyStaff            PropertyStaff[]
  reportedMaintenanceReqs  MaintenanceRequest[] @relation("ReportedBy")
  assignedMaintenanceReqs  MaintenanceRequest[] @relation("AssignedTo")
}

model Job {
  id                   String             @id @default(cuid())
  propertyId           String
  property             Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookingId            String?
  booking              Booking?           @relation(fields: [bookingId], references: [id])
  workerId             String?
  worker               Worker?            @relation(fields: [workerId], references: [id])
  type                 String
  status               String             @default("PENDING")
  scheduledAt          DateTime
  completedAt          DateTime?
  notes                String?
  checklist            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  issues             Issue[]
  maintenanceRequest MaintenanceRequest?
}

model Issue {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  description String
  photoUrl    String?
  videoUrl    String?
  severity    String   @default("LOW")
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id            String    @id @default(cuid())
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name          String
  category      String    @default("OTHER")
  currentStock  Float     @default(0)
  minStock      Float     @default(1)
  unit          String    @default("units")
  location      String?
  lastRestocked DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SupplyCabinet {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name        String
  location    String
  photoUrl    String?
  qrCode      String   @unique @default(cuid())
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Maintenance trade roles (host-defined) ──────────────────────────────────

model TradeRole {
  id          String   @id @default(cuid())
  hostId      String
  host        Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name        String   // e.g. "Plumber", "Carpenter", "Electrician"
  description String?
  color       String   @default("#6366f1") // display color
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workers             Worker[]
  maintenanceRequests MaintenanceRequest[]
}

// ── Property staff assignments ───────────────────────────────────────────────

model PropertyStaff {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workerId   String
  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  role       String   @default("CLEANER") // CARETAKER, CLEANER
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([propertyId, workerId])
}

// ── Per-property maintenance approval settings ───────────────────────────────

model PropertyMaintenanceSettings {
  id                   String   @id @default(cuid())
  propertyId           String   @unique
  property             Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requireApproval      Boolean  @default(true)
  autoAssignTradeRoles String   @default("[]") // JSON array of tradeRoleIds
  allowCaretakerAssign Boolean  @default(false) // caretaker can pick the tradesperson
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── Maintenance requests (raised by caretakers / cleaners) ───────────────────

model MaintenanceRequest {
  id               String     @id @default(cuid())
  propertyId       String
  property         Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reportedById     String
  reportedBy       Worker     @relation("ReportedBy", fields: [reportedById], references: [id])
  tradeRoleId      String?
  tradeRole        TradeRole? @relation(fields: [tradeRoleId], references: [id], onDelete: SetNull)
  title            String
  description      String
  photoUrl         String?
  videoUrl         String?
  priority         String     @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status           String     @default("PENDING") // PENDING, APPROVED, REJECTED, AUTO_ASSIGNED, ASSIGNED, IN_PROGRESS, COMPLETED
  assignedWorkerId String?
  assignedWorker   Worker?    @relation("AssignedTo", fields: [assignedWorkerId], references: [id])
  jobId            String?    @unique
  job              Job?       @relation(fields: [jobId], references: [id])
  hostNotes        String?
  scheduledAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

// ── Owner model ──────────────────────────────────────────────────────────────

model Owner {
  id        String             @id @default(cuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  properties PropertyOwnership[]
}

model PropertyOwnership {
  id               String   @id @default(cuid())
  ownerId          String
  owner            Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  propertyId       String
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  involvementLevel String   @default("REPORTS_ONLY") // NONE, REPORTS_ONLY, FINANCIAL, FULL
  ownershipPercent Float?
  commissionPct    Float?   // Management commission % taken from gross revenue
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([ownerId, propertyId])
}

// ── Revenue reports ───────────────────────────────────────────────────────────

model RevenueReport {
  id                String    @id @default(cuid())
  propertyId        String
  property          Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  hostId            String
  month             Int       // 1-12
  year              Int
  grossRevenue      Float     // Airbnb gross earnings (before Airbnb service fee)
  airbnbServiceFees Float     @default(0) // Airbnb's own service fees deducted
  netRevenue        Float     // grossRevenue - airbnbServiceFees (credited to host account)
  commissionPct     Float     @default(20) // Management commission %
  commissionAmount  Float     // Calculated commission amount
  airbnbReportUrl   String?   // Uploaded Airbnb report file URL
  status            String    @default("DRAFT") // DRAFT, PUBLISHED
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  expenses          Expense[]

  @@unique([propertyId, month, year])
}

model Expense {
  id               String        @id @default(cuid())
  reportId         String
  report           RevenueReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  propertyId       String
  category         String        // HOUSEKEEPING, CONSUMABLES, REPAIRS, UTILITIES, MISCELLANEOUS
  description      String
  amount           Float
  expenseType      String        @default("SHARED") // SHARED, OWNER_ONLY
  receiptUrl       String?
  requiresApproval Boolean       @default(false)
  approvalStatus   String        @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedByUserId String?
  approvedAt       DateTime?
  approverNotes    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}
