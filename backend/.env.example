DATABASE_URL="postgresql://livaround:livaround_secret@localhost:5432/livaround"
JWT_SECRET="change-me-to-a-long-random-secret"
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# Email (SMTP) — required for worker welcome emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Livaround <your-email@gmail.com>"

# Worker app URL sent in the welcome email
WORKER_APP_URL="http://localhost:3000/worker/login"
