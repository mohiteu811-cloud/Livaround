DATABASE_URL="postgresql://livaround:YOUR_PASSWORD_HERE@localhost:5432/livaround"
JWT_SECRET=          # REQUIRED — generate with: openssl rand -base64 32
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# Postgres (used by docker-compose)
POSTGRES_PASSWORD=   # REQUIRED — same password as in DATABASE_URL above

# Email (SMTP) — required for worker welcome emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=           # your SMTP email
SMTP_PASS=           # your SMTP app password
SMTP_FROM="Livaround <noreply@livaround.com>"

# Firebase Storage — required for file uploads
FIREBASE_SERVICE_ACCOUNT_JSON=   # REQUIRED — paste the full JSON service account key as a single line
FIREBASE_STORAGE_BUCKET=         # e.g. livaround-8fecf.firebasestorage.app

# Worker app URL sent in the welcome email
WORKER_APP_URL="http://localhost:3000/worker/login"

# WhatsApp Business Cloud API (Meta) — required for WhatsApp guest messaging
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=        # Meta Business phone number ID
WHATSAPP_ACCESS_TOKEN=           # Permanent system user access token
WHATSAPP_BUSINESS_ACCOUNT_ID=    # Meta Business Account ID
WHATSAPP_VERIFY_TOKEN=           # Custom token for webhook verification
WHATSAPP_APP_SECRET=             # App secret for webhook signature validation
GUEST_LINK_BASE_URL=             # e.g. https://livaround.com (for building guest links server-side)
