{
  "expo": {
    "name": "LivAround Host",
    "slug": "livaround-host",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "livaround-host",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.livaround.host",
      "infoPlist": {
        "NSCameraUsageDescription": "LivAround needs camera access to capture property photos.",
        "NSPhotoLibraryUsageDescription": "LivAround needs photo library access to upload images.",
        "NSFaceIDUsageDescription": "Use Face ID to unlock the app quickly."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.livaround.host",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "CAMERA"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      "./plugins/withAsyncStorageAndroidFix",
      "./plugins/withFirebaseMultiProcess",
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#3b82f6",
          "defaultChannel": "messages",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_HOST_APP_PROJECT_ID"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
