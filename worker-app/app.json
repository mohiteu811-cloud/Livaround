{
  "expo": {
    "name": "LivAround Worker",
    "slug": "livaroundgoa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "livaround-worker",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.livaround.worker",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "LivAround needs your location to help hosts track worker arrivals.",
        "NSLocationAlwaysUsageDescription": "LivAround needs background location to keep hosts updated on your whereabouts.",
        "NSLocationWhenInUseUsageDescription": "LivAround needs your location while using the app.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.livaround.worker",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      "./plugins/withAsyncStorageAndroidFix",
      "./plugins/withFirebaseMultiProcess",
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LivAround needs your location to help hosts track worker arrivals.",
          "locationAlwaysPermission": "LivAround needs background location to keep hosts updated on your whereabouts.",
          "locationWhenInUsePermission": "LivAround needs your location while using the app.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#3b82f6",
          "defaultChannel": "jobs",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "02df0810-cc85-4da0-b74e-dfc543be4cd2"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
