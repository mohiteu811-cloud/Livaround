generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One row per person who lists their home + specifies where they want to go.
model LivinbnbListing {
  id          String   @id @default(cuid())

  // Owner
  name        String
  email       String

  // Property (imported from URL — at least one of airbnbUrl / homeExchangeUrl required)
  airbnbUrl       String?
  homeExchangeUrl String?
  title       String
  location    String
  city        String
  country     String
  imageUrl    String?

  // Where they want to go
  destination     String
  destCity        String
  destCountry     String
  travelStart     DateTime
  travelEnd       DateTime

  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matchParticipations LivinbnbMatchParticipant[]
  destinationWishes   LivinbnbDestinationWish[]
}

// One row per wishlist destination for a listing.
// Replaces the single destCity/destCountry for matching purposes.
model LivinbnbDestinationWish {
  id        String          @id @default(cuid())
  listingId String
  listing   LivinbnbListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  city      String
  country   String
  display   String          // e.g. "London, UK"

  @@index([listingId])
}

// A match is a detected exchange cycle (2, 3, or 4-way).
model LivinbnbMatch {
  id        String   @id @default(cuid())
  wayCount  Int
  status    String   @default("PROPOSED")
  createdAt DateTime @default(now())

  participants LivinbnbMatchParticipant[]
}

model LivinbnbMatchParticipant {
  id        String          @id @default(cuid())
  matchId   String
  match     LivinbnbMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  listingId String
  listing   LivinbnbListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  position  Int

  @@unique([matchId, listingId])
  @@unique([matchId, position])
}

// Lead pipeline — potential hosts the CEO agent has identified / is pursuing
model LivinbnbLead {
  id          String   @id @default(cuid())
  name        String
  contact     String   // email, FB profile URL, or phone
  source      String   // e.g. "FB: Home Exchange Community", "HomeExchange.com search"
  location    String   // where their home is
  destination String   // where they want to go
  // IDENTIFIED → CONTACTED → RESPONDED → LISTED | DECLINED
  status      String   @default("IDENTIFIED")
  notes       String?
  followUpAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Scheduled outreach posts — one entry per FB group post to be made
model LivinbnbOutreachPost {
  id          String   @id @default(cuid())
  groupName   String
  groupUrl    String?
  copy        String
  scheduledAt DateTime
  // PENDING | DONE | SKIPPED
  status      String   @default("PENDING")
  fromCity    String?
  toCity      String?
  createdAt   DateTime @default(now())
}
