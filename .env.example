# ═══════════════════════════════════════════════════════
# LivAround — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.
# ═══════════════════════════════════════════════════════

# ─── Core ───────────────────────────────────────────────
# The URL where your app is running
NEXTAUTH_URL=http://localhost:3000

# A random secret for encrypting sessions (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-secret-here

# Node environment: development | production | test
NODE_ENV=development

# ─── Database ───────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/livaround

# Optional: Direct connection URL for Prisma (if using connection pooling)
# DIRECT_URL=postgresql://postgres:password@localhost:5432/livaround

# ─── Redis (Optional — for real-time features) ──────────
# REDIS_URL=redis://localhost:6379

# ─── Authentication ─────────────────────────────────────
# Google OAuth (optional — for Google sign-in)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email ──────────────────────────────────────────────
# Transactional email service (Resend recommended)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@livaround.com

# ─── File Storage ───────────────────────────────────────
# For issue photos, ops guide images, QR codes
# Options: local | supabase | s3

# STORAGE_PROVIDER=local
# STORAGE_LOCAL_PATH=./uploads

# Supabase Storage
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AWS S3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=livaround-uploads

# ─── Payment Processing ────────────────────────────────
# Razorpay (India)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your-razorpay-secret

# PayPal Subscriptions (primary billing)
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# PAYPAL_MODE=sandbox                          # sandbox | live
# PAYPAL_PLAN_ID_PRO=P-xxxxxxxxxxxxxxxxxxxx    # PayPal billing plan ID for Pro
# PAYPAL_PLAN_ID_AGENCY=P-xxxxxxxxxxxxxxxxxxxx # PayPal billing plan ID for Agency
# PAYPAL_WEBHOOK_ID=your-webhook-id

# Stripe (International)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── Channel Integrations (Premium) ────────────────────
# Airbnb iCal sync
# AIRBNB_ICAL_SYNC_ENABLED=false

# Booking.com Connectivity API
# BOOKINGCOM_API_KEY=your-api-key
# BOOKINGCOM_HOTEL_ID=your-hotel-id

# ─── Monitoring ─────────────────────────────────────────
# Sentry for error tracking
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Maps & GPS ─────────────────────────────────────────
# For live worker tracking map
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxxxxxx
# Or use Google Maps:
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# ─── App Configuration ──────────────────────────────────
# Default currency for new organizations
# DEFAULT_CURRENCY=INR

# Default timezone
# DEFAULT_TIMEZONE=Asia/Kolkata

# Max file upload size in MB
# MAX_UPLOAD_SIZE_MB=10

# GPS tracking update interval in seconds
# GPS_UPDATE_INTERVAL=15

# ─── Commercial / Payments ──────────────────────────────
# Set to true to enable payment processing and commercial features.
# When false the app runs as fully open-source with no limits.
PAYMENTS_ENABLED=false

# ─── Self-Hosting Specific ──────────────────────────────
# Set to true if running behind a reverse proxy
# TRUST_PROXY=false

# Custom port (default: 3000)
# PORT=3000
